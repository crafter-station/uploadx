{
  "name": "@uploadx-sdk/react",
  "version": "0.2.0",
  "description": "React components and hooks for uploadx — UploadButton, UploadDropzone, useUploadX",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "upload",
    "file-upload",
    "react",
    "uploadthing",
    "upload-button",
    "upload-dropzone",
    "hooks"
  ],
  "author": "Ignacio",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ignac/uploadx",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/Ignac/uploadx#readme",
  "bugs": {
    "url": "https://github.com/Ignac/uploadx/issues"
  },
  "dependencies": {
    "@uploadx-sdk/core": "^0.2.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
