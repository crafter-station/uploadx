{
  "name": "@uploadx-sdk/core",
  "version": "0.3.0",
  "description": "Open-source file upload SDK using MinIO — UploadThing API-compatible",
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js",
      "require": "./dist/next/index.cjs"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js",
      "require": "./dist/db/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "lint": "biome lint .",
    "clean": "rm -rf dist .turbo"
  },
  "keywords": [
    "upload",
    "file-upload",
    "minio",
    "s3",
    "presigned-url",
    "uploadthing",
    "nextjs",
    "react"
  ],
  "author": "Ignacio",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ignac/uploadx"
  },
  "homepage": "https://github.com/Ignac/uploadx#readme",
  "bugs": {
    "url": "https://github.com/Ignac/uploadx/issues"
  },
  "dependencies": {
    "minio": "^8.0.1"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "drizzle-orm": ">=0.30.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0",
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
